<!-- components/settings-view/settings-view.wxml -->
<view class="view-container">
  <!-- Card 1: Translation Settings -->
  <view class="card settings-card">
    <view class="card-title">百度翻译配置</view>
    <view class="card-subtitle">请配置您的百度翻译 APP ID 和密钥以支持自定义中文的翻译</view>
    
    <view class="baidu-form">
      <view class="form-item">
        <text class="form-label">百度翻译 AppID</text>
        <input 
          class="form-input" 
          placeholder="请输入 AppID" 
          value="{{baiduAppId}}" 
          bindinput="onInputAppId" 
        />
      </view>
      <view class="form-item">
        <text class="form-label">百度翻译 密钥 (Key)</text>
        <input 
          class="form-input" 
          password 
          placeholder="请输入密钥" 
          value="{{baiduApiKey}}" 
          bindinput="onInputApiKey" 
        />
      </view>
      <button class="btn btn-primary save-key-btn" bindtap="onSaveBaiduKeys">保存配置</button>
    </view>
  </view>

  <!-- Card 2: TTS Settings -->
  <view class="card settings-card">
    <view class="card-title">发音朗读设置</view>
    
    <view class="settings-row">
      <text class="row-label">发音语速</text>
      <view class="rate-selector">
        <view 
          class="rate-option {{config.speechRate === 0.75 ? 'active' : ''}}" 
          data-rate="{{0.75}}" 
          bindtap="onSelectRate"
        >
          0.75x
        </view>
        <view 
          class="rate-option {{config.speechRate === 1.0 ? 'active' : ''}}" 
          data-rate="{{1.0}}" 
          bindtap="onSelectRate"
        >
          1.0x
        </view>
        <view 
          class="rate-option {{config.speechRate === 1.25 ? 'active' : ''}}" 
          data-rate="{{1.25}}" 
          bindtap="onSelectRate"
        >
          1.25x
        </view>
        <view 
          class="rate-option {{config.speechRate === 1.5 ? 'active' : ''}}" 
          data-rate="{{1.5}}" 
          bindtap="onSelectRate"
        >
          1.5x
        </view>
        <view 
          class="rate-option {{config.speechRate === 2.0 ? 'active' : ''}}" 
          data-rate="{{2.0}}" 
          bindtap="onSelectRate"
        >
          2.0x (上限)
        </view>
      </view>
    </view>

    <view class="settings-row google-tts-row">
      <view class="row-left">
        <text class="row-label">启用 Google 高级发音通道</text>
        <view class="row-desc">仅限身处国外的用户开启（以获得最佳整句人声发音）。国内用户请保持关闭，直接使用免配置的默认发音通道（已针对连贯度和语速完成深度优化）。</view>
      </view>
      <switch checked="{{config.useGoogleTTS}}" bindchange="onToggleGoogleTTS" color="#10B981" />
    </view>
  </view>

  <!-- Card 3: Custom User Dictionary -->
  <view class="card settings-card">
    <view class="card-title-row">
      <text class="card-title">本地自定义词库</text>
      <text class="card-badge" wx:if="{{customWords.length > 0}}">{{customWords.length}} 词</text>
    </view>
    <view class="card-subtitle">查看或删除您在翻译过程中添加/纠正的单词释义</view>
    
    <view class="empty-dict" wx:if="{{customWords.length === 0}}">
      <text class="empty-dict-text">暂无自定义词汇</text>
      <text class="empty-dict-sub">在翻译结果中点击 [未知读音/释义] 的单词即可手动添加补充</text>
    </view>
    
    <view class="dict-list" wx:else>
      <view class="dict-item" wx:for="{{customWords}}" wx:key="word">
        <view class="dict-left">
          <text class="dict-word">{{item.word}}</text>
          <text class="dict-phonetic">[{{item.phonetic}}]</text>
        </view>
        <view class="dict-right">
          <text class="dict-meaning">{{item.meaning}}</text>
          <view class="dict-delete" data-word="{{item.word}}" bindtap="onDeleteCustomWord">✕</view>
        </view>
      </view>
    </view>
  </view>

  <!-- Card 4: Data Management -->
  <view class="card settings-card">
    <view class="card-title">数据管理</view>
    <view class="data-actions">
      <button class="btn-data btn-danger-outline" bindtap="onClearHistoryData">
        🗑️ 清空学习笔记本历史
      </button>
      <button class="btn-data btn-danger-outline" bindtap="onClearUserDictData">
        🗑️ 清空本地自定义词库
      </button>
    </view>
  </view>

  <!-- Card 5: Guide/Help -->
  <view class="card info-card">
    <view class="card-title">关于与使用指南</view>
    <view class="info-content">
      <view class="info-p">1. **本小程序承诺完全免费**：所有翻译和学习记录均储存在您手机本地的缓存中，绝不上传到任何服务器，保护您的隐私。</view>
      <view class="info-p">2. **关于发音**：发音服务采用有道泰语发音通道，国内网络环境秒开，发音清晰标准，无需任何配置，即开即用。</view>
      <view class="info-p">3. **如何免费注册百度翻译**：
        <view class="info-sub-p">• 微信搜索或电脑访问“百度翻译开放平台”。</view>
        <view class="info-sub-p">• 注册个人开发者账号（完全免费）。</view>
        <view class="info-sub-p">• 实名认证后，在“管理控制台”申请开通“通用文本翻译 API”。</view>
        <view class="info-sub-p">• 申请成功后可在控制台下方获取到您的 AppID 和 密钥，填入上方保存即可。</view>
      </view>
    </view>
  </view>
</view>
