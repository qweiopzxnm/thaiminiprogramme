<!-- components/import-view/import-view.wxml -->
<view class="view-container">
  <!-- 1. 编辑录入模式 -->
  <block wx:if="{{!previewMode}}">
    <!-- 提示卡片 -->
    <view class="card tip-card">
      <view class="tip-header">
        <text class="tip-icon">💡</text>
        <text class="tip-title">导入说明</text>
      </view>
      <view class="tip-body">
        <text class="tip-text">您可以直接在这里粘贴书籍、网页中已经做过拼音释义标注的泰语学习段落。系统会自动解析为笔记本中的卡片，并将其中的生词录入本地字典。</text>
        <view class="example-box">
          <text class="example-title">支持格式样例：</text>
          <text class="example-content">“ลูกค้า” = 客人 (lûuk-kháa)
“ให้” = 提供 (hâi)
“ข้อกำหนด” = 要求 (khâaw-gam-nòt)

ลูกค้าให้ข้อกำหนด</text>
        </view>
      </view>
    </view>

    <!-- 输入卡片 -->
    <view class="card input-card">
      <view class="section-title-row">
        <text class="section-title">粘贴学习内容</text>
      </view>
      <textarea 
        class="import-textarea" 
        placeholder="{{placeholderText}}" 
        value="{{inputText}}" 
        bindinput="onInputText"
        maxlength="2000"
      />
    </view>

    <!-- 翻译输入卡片 -->
    <view class="card translation-card">
      <view class="section-title-row">
        <text class="section-title">整句中文翻译 (选填)</text>
      </view>
      <input 
        class="translation-input" 
        placeholder="例如: 客户提出要求。不填则保存时自动后台翻译" 
        value="{{chineseTranslation}}" 
        bindinput="onInputChinese"
      />
    </view>

    <view class="btn-group">
      <button class="btn btn-secondary" bindtap="onClear" wx:if="{{inputText.length > 0}}">清空</button>
      <button class="btn btn-primary" bindtap="onParse">解析并预览</button>
    </view>
  </block>

  <!-- 2. 预览模式 -->
  <block wx:else>
    <!-- 预览卡片 -->
    <view class="card preview-card">
      <view class="preview-header">
        <text class="preview-title">解析预览</text>
        <text class="preview-subtitle">（请确认提取的句子与词汇是否正确）</text>
      </view>
      
      <view class="preview-section">
        <text class="preview-label">泰语原文：</text>
        <view class="preview-thai-box">
          <text class="preview-thai-text">{{parsedSentence}}</text>
        </view>
      </view>

      <view class="preview-section">
        <text class="preview-label">中文翻译：</text>
        <view class="preview-zh-box">
          <text class="preview-zh-text" wx:if="{{chineseTranslation}}">{{chineseTranslation}}</text>
          <text class="preview-zh-text placeholder" wx:else>💡 未填写，保存时将自动调用网络翻译补全</text>
        </view>
      </view>
    </view>

    <!-- 单词拆解预览 -->
    <view class="section-title-row">
      <text class="section-title">提取的单词列表 (共 {{parsedWords.length}} 个)</text>
    </view>

    <view class="word-list">
      <view class="word-item" wx:for="{{parsedWords}}" wx:key="word">
        <view class="word-line-box">
          <text class="word-thai">“{{item.word}}”</text>
          <text class="word-equal"> = </text>
          <text class="word-meaning">{{item.meaning}}</text>
          <text class="word-phonetic">({{item.phonetic}})</text>
        </view>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn btn-secondary" bindtap="onBackToEdit">返回修改</button>
      <button class="btn btn-primary" bindtap="onSaveImport" loading="{{loading}}">确认保存并学习</button>
    </view>
  </block>
</view>
