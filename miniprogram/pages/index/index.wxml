<!--pages/index/index.wxml-->
<navigation-bar title="{{navTitle}}" back="{{false}}" color="#111827" background="#FFFFFF"></navigation-bar>

<!-- 全局音频下载进度条 -->
<view class="global-audio-progress-container {{showAudioProgress ? 'show' : ''}}">
  <view class="global-audio-progress-bar" style="width: {{audioLoadingProgress}}%"></view>
</view>

<view class="page-container">
  <!-- View Container -->
  <view class="view-wrapper">
    <translate-view 
      id="translateView" 
      class="view-item" 
      wx:if="{{activeTab === 'translate'}}" 
      bind:historychange="onHistoryChange"
    ></translate-view>

    <scenarios-view
      id="scenariosView"
      class="view-item"
      wx:elif="{{activeTab === 'scenarios'}}"
      bind:historychange="onHistoryChange"
    ></scenarios-view>
    
    <review-view 
      id="reviewView" 
      class="view-item" 
      wx:elif="{{activeTab === 'review'}}" 
      bind:historychange="onHistoryChange"
    ></review-view>
  </view>
  
  <!-- Custom TabBar -->
  <view class="custom-tab-bar">
    <view class="tab-item {{activeTab === 'translate' ? 'active' : ''}}" data-tab="translate" bindtap="onSwitchTab">
      <image class="tab-icon" src="/assets/icons/translate{{activeTab === 'translate' ? '-active' : ''}}.svg" />
      <text class="tab-text">翻译</text>
    </view>
    <view class="tab-item {{activeTab === 'scenarios' ? 'active' : ''}}" data-tab="scenarios" bindtap="onSwitchTab">
      <image class="tab-icon" src="/assets/icons/scenarios{{activeTab === 'scenarios' ? '-active' : ''}}.svg" />
      <text class="tab-text">情景</text>
    </view>
    <view class="tab-item {{activeTab === 'review' ? 'active' : ''}}" data-tab="review" bindtap="onSwitchTab">
      <image class="tab-icon" src="/assets/icons/review{{activeTab === 'review' ? '-active' : ''}}.svg" />
      <text class="tab-text">笔记本</text>
    </view>
  </view>
</view>
